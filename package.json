{
  "name": "gdrive-mcp",
  "version": "0.1.0",
  "description": "MCP Server for Google Drive (and Google APIs)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "auth": "node --env-file=.env dist/auth-cli.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": ["mcp", "google", "drive", "gdrive"],
  "author": "Secretary Project",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "googleapis": "^148.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
