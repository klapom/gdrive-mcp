# Google Drive MCP - OAuth2 credentials from Google Cloud Console
# 1. Go to console.cloud.google.com
# 2. Create project → Enable "Google Drive API"
# 3. APIs & Services → Credentials → Create → OAuth 2.0 Client ID → Desktop app
# 4. Download JSON → copy client_id and client_secret here

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Optional: path to token cache (default: ~/.gdrive-mcp/token.json)
# GOOGLE_TOKEN_PATH=~/.gdrive-mcp/token.json
